<Window x:Class="NovaGamingOptimizer.DashboardOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nova Dashboard" Height="285" Width="195"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ShowInTaskbar="False" Left="10" Top="10"
        MouseDown="Window_MouseDown">
    <Border Background="#CC04000E" BorderBrush="#440088" BorderThickness="1" CornerRadius="10">
        <StackPanel Margin="12">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Width="16" Height="16" CornerRadius="4" Margin="0,0,6,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00FF88" Offset="0"/>
                                <GradientStop Color="#00D4FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="N" FontSize="10" FontWeight="Black" Foreground="#080015"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="NOVA" FontSize="11" FontWeight="Black" Foreground="#00FF88" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="X" Click="CloseOverlay"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#FF4444" FontSize="11" Cursor="Hand"/>
            </Grid>
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions><ColumnDefinition Width="45"/><ColumnDefinition Width="*"/><ColumnDefinition Width="38"/></Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="CPU" FontSize="10" Foreground="#555577" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" x:Name="CpuBar" Height="3" Background="#1A0033" Foreground="#00FF88" BorderThickness="0" VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Grid.Column="2" x:Name="CpuText" Text="0%" FontSize="11" FontWeight="Bold" Foreground="#00FF88" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions><ColumnDefinition Width="45"/><ColumnDefinition Width="*"/><ColumnDefinition Width="38"/></Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="GPU" FontSize="10" Foreground="#555577" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" x:Name="GpuBar" Height="3" Background="#1A0033" Foreground="#FF00FF" BorderThickness="0" VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Grid.Column="2" x:Name="GpuText" Text="0%" FontSize="11" FontWeight="Bold" Foreground="#FF00FF" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions><ColumnDefinition Width="45"/><ColumnDefinition Width="*"/><ColumnDefinition Width="38"/></Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="RAM" FontSize="10" Foreground="#555577" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" x:Name="RamBar" Height="3" Background="#1A0033" Foreground="#00D4FF" BorderThickness="0" VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Grid.Column="2" x:Name="RamText" Text="0%" FontSize="11" FontWeight="Bold" Foreground="#00D4FF" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions><ColumnDefinition Width="45"/><ColumnDefinition Width="*"/><ColumnDefinition Width="38"/></Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="PING" FontSize="10" Foreground="#555577" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" x:Name="PingBar" Height="3" Background="#1A0033" Foreground="#FFAA00" BorderThickness="0" VerticalAlignment="Center" Margin="4,0" Maximum="300"/>
                <TextBlock Grid.Column="2" x:Name="PingText" Text="0ms" FontSize="11" FontWeight="Bold" Foreground="#FFAA00" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions><ColumnDefinition Width="45"/><ColumnDefinition Width="*"/><ColumnDefinition Width="38"/></Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="TEMP" FontSize="10" Foreground="#555577" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" x:Name="TempBar" Height="3" Background="#1A0033" Foreground="#FF4444" BorderThickness="0" VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Grid.Column="2" x:Name="TempText" Text="0C" FontSize="11" FontWeight="Bold" Foreground="#FF4444" HorizontalAlignment="Right"/>
            </Grid>
            <Border Background="#0A0020" CornerRadius="6" Margin="0,0,0,10">
                <StackPanel Margin="8,6">
                    <TextBlock Text="FPS" FontSize="9" Foreground="#444466" Margin="0,0,0,2"/>
                    <TextBlock x:Name="FpsText" Text="-- fps" FontSize="22" FontWeight="Black" Foreground="#00FF88"/>
                    <TextBlock x:Name="GameText" Text="No game detected" FontSize="9" Foreground="#444466"/>
                </StackPanel>
            </Border>
            <Border Background="#0A0010" CornerRadius="6">
                <StackPanel Margin="8,6">
                    <TextBlock Text="Overlay Color" FontSize="9" Foreground="#444466" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="ColorDot" Width="20" Height="20" CornerRadius="4" Background="#00FF88" Margin="0,0,6,0"/>
                        <TextBox x:Name="HexInput" Text="#00FF88"
                                 Background="#111" Foreground="#00FF88"
                                 BorderBrush="#2A0044" BorderThickness="1"
                                 FontFamily="Courier New" FontSize="11"
                                 Width="75" VerticalContentAlignment="Center"
                                 TextChanged="HexInput_Changed"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>
