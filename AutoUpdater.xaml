<Window x:Class="NovaGamingOptimizer.AutoUpdater"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nova Update" Height="270" Width="460"
        Background="#0F0F0F" Foreground="#FFFFFF"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="TitleText" Text="Checking for Updates..." FontSize="16" FontWeight="Black" Foreground="#00FF88"/>
            <TextBlock x:Name="SubText" Text="Please wait..." FontSize="11" Foreground="#555577" Margin="0,3,0,0"/>
        </StackPanel>
        <Border Grid.Row="1" Background="#161616" BorderBrush="#2A2A3A" BorderThickness="1" CornerRadius="8" Margin="0,0,0,12">
            <StackPanel Margin="14,10">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Current:" Foreground="#444466" FontSize="11" Width="100"/>
                    <TextBlock x:Name="CurrentVersionText" Text="v1.0.0" Foreground="#FFFFFF" FontSize="11" FontWeight="Bold" FontFamily="Courier New"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Latest:" Foreground="#444466" FontSize="11" Width="100"/>
                    <TextBlock x:Name="LatestVersionText" Text="Checking..." Foreground="#00FF88" FontSize="11" FontWeight="Bold" FontFamily="Courier New"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Status:" Foreground="#444466" FontSize="11" Width="100"/>
                    <TextBlock x:Name="StatusText" Text="Checking..." Foreground="#FFAA00" FontSize="11" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <ProgressBar x:Name="ProgressBar" Grid.Row="2" Height="4" Margin="0,0,0,12"
                     Background="#161616" Foreground="#00FF88" BorderThickness="0"
                     Minimum="0" Maximum="100" Value="0" IsIndeterminate="True"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="SkipButton" Content="Skip" Click="Skip_Click"
                    Background="#161616" Foreground="#888888" BorderBrush="#2A2A3A" BorderThickness="1"
                    Padding="16,7" Margin="0,0,8,0" Cursor="Hand"/>
            <Button x:Name="UpdateButton" Content="Download Update" Click="Update_Click"
                    Background="#00FF88" Foreground="#000000" BorderThickness="0"
                    Padding="16,7" FontWeight="Bold" IsEnabled="False" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
