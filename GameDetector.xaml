<Window x:Class="NovaGamingOptimizer.GameDetector"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nova Gaming Optimizer" Height="600" Width="960"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown">
    <Window.Resources>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="13,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="#0F0F0F" BorderBrush="#2A2A3A" BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="#161616">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Border Width="22" Height="22" CornerRadius="6" Margin="0,0,8,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00FF88" Offset="0"/>
                                <GradientStop Color="#00D4FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="N" FontSize="13" FontWeight="Black" Foreground="#080015"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="NOVA OPTIMIZER" FontSize="12" FontWeight="Bold"
                               Foreground="#00FF88" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                    <Button Style="{StaticResource WinBtn}" Foreground="#888888"
                            Click="MinimizeWindow" Content="─" BorderThickness="0" Background="Transparent"/>
                    <Button Style="{StaticResource WinBtn}" Foreground="#888888"
                            Click="MaximizeWindow" Content="□" BorderThickness="0" Background="Transparent"/>
                    <Button Style="{StaticResource WinBtn}" Foreground="#FF4444"
                            Click="CloseWindow" Content="X" BorderThickness="0" Background="Transparent"/>
                </StackPanel>
            </Grid>
            <Border Grid.Row="1" Background="#111111" BorderBrush="#1A1A1A" BorderThickness="0,0,0,1">
                <StackPanel Margin="18,12,18,12">
                    <TextBlock Text="NOVA GAME DETECTOR" FontSize="20" FontWeight="Black"
                               Foreground="#00FF88" Margin="0,0,0,4"/>
                    <TextBlock Text="Scanning your system for installed games..." FontSize="11"
                               Foreground="#555577" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Dashboard" Click="OpenDashboard_Click"
                                Style="{StaticResource Btn}"
                                Background="#0A1A0A" BorderBrush="#00FF88" BorderThickness="1"
                                Foreground="#00FF88" Margin="0,0,8,0"/>
                        <Button Content="Network" Click="OpenNetwork_Click"
                                Style="{StaticResource Btn}"
                                Background="#0A0A1A" BorderBrush="#00D4FF" BorderThickness="1"
                                Foreground="#00D4FF" Margin="0,0,8,0"/>
                        <Button Content="Mouse" Click="OpenMouse_Click"
                                Style="{StaticResource Btn}"
                                Background="#1A0A1A" BorderBrush="#FF00FF" BorderThickness="1"
                                Foreground="#FF00FF" Margin="0,0,8,0"/>
                        <Button Content="Keyboard" Click="OpenKeyboard_Click"
                                Style="{StaticResource Btn}"
                                Background="#1A1A0A" BorderBrush="#FFAA00" BorderThickness="1"
                                Foreground="#FFAA00" Margin="0,0,8,0"/>
                        <Button Content="Audio" Click="OpenAudio_Click"
                                Style="{StaticResource Btn}"
                                Background="#1A0A0A" BorderBrush="#FF4444" BorderThickness="1"
                                Foreground="#FF4444" Margin="0,0,8,0"/>
                        <Button Content="Crosshair" Click="OpenCrosshair_Click"
                                Style="{StaticResource Btn}"
                                Background="#0D0A1A" BorderBrush="#8844FF" BorderThickness="1"
                                Foreground="#8844FF"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Grid Grid.Row="2" Margin="18,14,18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="DETECTED GAMES" FontSize="10" FontWeight="Bold"
                               Foreground="#444466" Margin="0,0,0,8"/>
                    <ListBox Name="GamesList" Background="#161616" Foreground="#FFFFFF"
                             BorderBrush="#2A2A3A" BorderThickness="1"
                             SelectionChanged="GamesList_SelectionChanged"
                             Height="360">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1A0033"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A1A2E"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="10,6">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                               Foreground="#00FF88" FontSize="12"/>
                                    <TextBlock Text="{Binding Path}" FontSize="10"
                                               Foreground="#444466" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Name="GamesCountLabel" Text="Total: 0 games"
                               Foreground="#444466" Margin="0,8,0,0" FontSize="11"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#161616" BorderBrush="#2A2A3A"
                        BorderThickness="1" CornerRadius="8">
                    <StackPanel Margin="16">
                        <TextBlock Text="GAME DETAILS" FontSize="10" FontWeight="Bold"
                                   Foreground="#444466" Margin="0,0,0,14"/>
                        <TextBlock Text="Name:" Foreground="#00FF88" FontSize="11" Margin="0,0,0,3"/>
                        <TextBlock Name="DetailName" Text="Select a game..." Foreground="#CCCCEE"
                                   TextWrapping="Wrap" Margin="0,0,0,12" FontSize="13"/>
                        <TextBlock Text="Full Path:" Foreground="#00FF88" FontSize="11" Margin="0,0,0,3"/>
                        <TextBlock Name="DetailPath" Text="-" Foreground="#555577"
                                   TextWrapping="Wrap" FontFamily="Courier New"
                                   FontSize="10" Margin="0,0,0,12"/>
                        <TextBlock Text="File Size:" Foreground="#00FF88" FontSize="11" Margin="0,0,0,3"/>
                        <TextBlock Name="DetailSize" Text="-" Foreground="#CCCCEE"
                                   Margin="0,0,0,12" FontSize="12"/>
                        <TextBlock Text="Engine:" Foreground="#00FF88" FontSize="11" Margin="0,0,0,3"/>
                        <TextBlock Name="DetailEngine" Text="Unknown" Foreground="#CCCCEE"
                                   Margin="0,0,0,24" FontSize="12"/>
                        <Button Name="LaunchButton" Content="LAUNCH GAME"
                                Click="LaunchButton_Click" IsEnabled="False"
                                Style="{StaticResource Btn}"
                                Background="#00FF88" Foreground="#000000"
                                BorderThickness="0" Margin="0,0,0,8"/>
                        <Button Name="OpenFolderButton" Content="OPEN FOLDER"
                                Click="OpenFolderButton_Click" IsEnabled="False"
                                Style="{StaticResource Btn}"
                                Background="#0A0A1A" Foreground="#00D4FF"
                                BorderBrush="#00D4FF" BorderThickness="1"/>
                    </StackPanel>
                </Border>
            </Grid>
            <Border Grid.Row="3" Background="#161616" BorderBrush="#1A1A1A" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,18,0">
                    <Button Name="RefreshButton" Content="Refresh"
                            Click="RefreshButton_Click" Style="{StaticResource Btn}"
                            Background="#00FF88" Foreground="#000000"
                            BorderThickness="0" Margin="0,0,8,0"/>
                    <Button Content="Web" Click="OpenWebButton_Click"
                            Style="{StaticResource Btn}"
                            Background="#0A0A1A" Foreground="#FF00FF"
                            BorderBrush="#FF00FF" BorderThickness="1" Margin="0,0,8,0"/>
                    <Button Content="Discord" Click="Discord_Click"
                            Style="{StaticResource Btn}"
                            Background="#0A0F1A" Foreground="#7289DA"
                            BorderBrush="#7289DA" BorderThickness="1" Margin="0,0,8,0"/>
                    <Button Content="PayPal" Click="PayPal_Click"
                            Style="{StaticResource Btn}"
                            Background="#1A0020" Foreground="#FF00AA"
                            BorderBrush="#FF00AA" BorderThickness="1"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
