<Window x:Class="NovaGamingOptimizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NOVA Gaming Optimizer"
        Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- Nav Button Style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Width" Value="180"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="6,0">
                            <Grid>
                                <Border x:Name="accent" Width="3" HorizontalAlignment="Left"
                                        CornerRadius="2" Background="Transparent" Margin="0,8"/>
                                <ContentPresenter Margin="28,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#252545"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="border" Property="Background" Value="#1E2A4A"/>
                                <Setter TargetName="accent" Property="Background" Value="#3B82F6"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#141428"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="6"/>
        </Style>

        <!-- TitleBar Button Style -->
        <Style x:Key="TitleBarBtn" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#2A2A4A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close Button Style -->
        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource TitleBarBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#E53E3E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Style -->
        <Style x:Key="Toggle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="track" Width="44" Height="24" CornerRadius="12"
                                    Background="#2A2A4A" HorizontalAlignment="Left"/>
                            <Ellipse x:Name="thumb" Width="18" Height="18" Fill="White"
                                     HorizontalAlignment="Left" VerticalAlignment="Center"
                                     Margin="3,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="#3B82F6"/>
                                <Setter TargetName="thumb" Property="Margin" Value="23,0,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Container with shadow -->
    <Border CornerRadius="14" Background="#0D0D1F">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#000000" Opacity="0.7"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════ SIDEBAR ═══════════════ -->
            <Border Grid.Column="0" Background="#0A0A1A" CornerRadius="14,0,0,14">
                <DockPanel>
                    <!-- Logo -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,24,0,20">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3B82F6" Offset="0"/>
                                        <GradientStop Color="#8B5CF6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="N" FontSize="18" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="NOVA" FontSize="16" FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock Text="Gaming Optimizer" FontSize="9"
                                           Foreground="#5566AA"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Height="1" Background="#1A1A3A" Margin="16,16,16,0"/>
                    </StackPanel>

                    <!-- Bottom Links -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,16">
                        <Border Height="1" Background="#1A1A3A" Margin="16,0,16,12"/>
                        <Button Style="{StaticResource NavButton}" Click="Web_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌐" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="Website"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Click="Discord_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💬" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="Discord"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButton}" Click="PayPal_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💙" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="Support Us"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="v1.0.5" FontSize="10" Foreground="#333366"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Nav Items -->
                    <StackPanel Margin="0,0,0,0">
                        <TextBlock Text="MAIN" FontSize="10" FontWeight="Bold"
                                   Foreground="#334" Margin="22,0,0,6" LetterSpacing="2"/>
                        <Button x:Name="BtnDashboard" Style="{StaticResource NavButton}"
                                Tag="Active" Click="Nav_Click" CommandParameter="Dashboard">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚡" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="Dashboard"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnGames" Style="{StaticResource NavButton}"
                                Click="Nav_Click" CommandParameter="Games">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎮" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="Game Library"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="TOOLS" FontSize="10" FontWeight="Bold"
                                   Foreground="#334" Margin="22,14,0,6" LetterSpacing="2"/>
                        <Button x:Name="BtnOptimize" Style="{StaticResource NavButton}"
                                Click="Nav_Click" CommandParameter="Optimize">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚀" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="Optimizer"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnMouse" Style="{StaticResource NavButton}"
                                Click="Nav_Click" CommandParameter="Mouse">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🖱️" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="Mouse Tweaks"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnKeyboard" Style="{StaticResource NavButton}"
                                Click="Nav_Click" CommandParameter="Keyboard">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⌨️" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="Keyboard"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnAudio" Style="{StaticResource NavButton}"
                                Click="Nav_Click" CommandParameter="Audio">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔊" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="Audio"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnNetwork" Style="{StaticResource NavButton}"
                                Click="Nav_Click" CommandParameter="Network">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📡" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="Network"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnCrosshair" Style="{StaticResource NavButton}"
                                Click="Nav_Click" CommandParameter="Crosshair">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎯" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="Crosshair"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ═══════════════ MAIN CONTENT ═══════════════ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <Border Grid.Row="0" Background="#0D0D1F" CornerRadius="0,14,0,0">
                    <Grid Margin="16,0">
                        <TextBlock x:Name="PageTitle" Text="Dashboard"
                                   Foreground="#FFFFFF" FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Style="{StaticResource TitleBarBtn}" Content="─"
                                    Click="Minimize_Click" ToolTip="Minimize"/>
                            <Button Style="{StaticResource TitleBarBtn}" Content="□"
                                    Click="Maximize_Click" ToolTip="Maximize"/>
                            <Button Style="{StaticResource CloseBtn}" Content="✕"
                                    Click="Close_Click" ToolTip="Close"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Pages Container -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="10,10,16,16">

                        <!-- ═══ DASHBOARD PAGE ═══ -->
                        <StackPanel x:Name="PageDashboard" Visibility="Visible">
                            <!-- Stats Row -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="CPU USAGE" FontSize="10" Foreground="#556"
                                                   FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="CpuLabel" Text="--%" FontSize="28"
                                                   FontWeight="Bold" Foreground="#3B82F6"/>
                                        <TextBlock x:Name="CpuName" Text="Loading..." FontSize="10"
                                                   Foreground="#556" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="RAM USAGE" FontSize="10" Foreground="#556"
                                                   FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="RamLabel" Text="--%" FontSize="28"
                                                   FontWeight="Bold" Foreground="#8B5CF6"/>
                                        <TextBlock x:Name="RamDetail" Text="Loading..." FontSize="10"
                                                   Foreground="#556" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="GPU" FontSize="10" Foreground="#556"
                                                   FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="GpuLabel" Text="--°C" FontSize="28"
                                                   FontWeight="Bold" Foreground="#10B981"/>
                                        <TextBlock x:Name="GpuName" Text="Loading..." FontSize="10"
                                                   Foreground="#556" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="PING" FontSize="10" Foreground="#556"
                                                   FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="PingLabel" Text="-- ms" FontSize="28"
                                                   FontWeight="Bold" Foreground="#F59E0B"/>
                                        <TextBlock Text="8.8.8.8" FontSize="10"
                                                   Foreground="#556" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Game Mode + Quick Actions -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Game Mode Card -->
                                <Border Grid.Column="0" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="GAME MODE" FontSize="10" Foreground="#556"
                                                   FontWeight="Bold" Margin="0,0,0,12"/>
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock x:Name="GameModeStatus" Text="Inactive"
                                                           FontSize="22" FontWeight="Bold" Foreground="#666"/>
                                                <TextBlock Text="Disables background processes &amp; boosts CPU priority"
                                                           FontSize="11" Foreground="#445" Margin="0,6,0,14"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                        <Button Style="{StaticResource ActionButton}"
                                                x:Name="BtnToggleGameMode"
                                                Content="⚡  Enable Game Mode"
                                                Click="ToggleGameMode_Click" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>

                                <!-- Quick Actions -->
                                <Border Grid.Column="1" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="QUICK ACTIONS" FontSize="10" Foreground="#556"
                                                   FontWeight="Bold" Margin="0,0,0,12"/>
                                        <Button Style="{StaticResource ActionButton}"
                                                Content="🧹  Clean RAM" Click="Optimize_Click"
                                                Margin="0,0,0,8" HorizontalAlignment="Stretch"/>
                                        <Button Style="{StaticResource ActionButton}"
                                                Content="🎮  Open Game Library" Click="Games_Click"
                                                Background="#1E3A5F" Margin="0,0,0,8"
                                                HorizontalAlignment="Stretch"/>
                                        <Button Style="{StaticResource ActionButton}"
                                                Content="📡  Ping Test" Click="Network_Click"
                                                Background="#1A3A2A" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- System Info -->
                            <Border Style="{StaticResource Card}" Margin="6,2,6,6">
                                <StackPanel>
                                    <TextBlock Text="SYSTEM INFO" FontSize="10" Foreground="#556"
                                               FontWeight="Bold" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="OS" FontSize="10" Foreground="#445"/>
                                            <TextBlock x:Name="OsLabel" Text="Windows" FontSize="13"
                                                       Foreground="#CCC" Margin="0,2"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="UPTIME" FontSize="10" Foreground="#445"/>
                                            <TextBlock x:Name="UptimeLabel" Text="--" FontSize="13"
                                                       Foreground="#CCC" Margin="0,2"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="DISK" FontSize="10" Foreground="#445"/>
                                            <TextBlock x:Name="DiskLabel" Text="--" FontSize="13"
                                                       Foreground="#CCC" Margin="0,2"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ═══ GAME LIBRARY PAGE ═══ -->
                        <StackPanel x:Name="PageGames" Visibility="Collapsed">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <TextBlock Text="Game Library" FontSize="18" FontWeight="Bold"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                        <Button Style="{StaticResource ActionButton}" Content="+ Add Game"
                                                HorizontalAlignment="Right" Click="Games_Click"/>
                                    </Grid>
                                    <ItemsControl x:Name="GamesList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1A1A30" CornerRadius="8"
                                                        Margin="0,4" Padding="14,10">
                                                    <Grid>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="40" Height="40" CornerRadius="6"
                                                                    Background="#252545" Margin="0,0,12,0">
                                                                <TextBlock Text="🎮" FontSize="20"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Name}" FontSize="14"
                                                                           Foreground="White" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding Source}" FontSize="11"
                                                                           Foreground="#556"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Button Content="▶ Launch" HorizontalAlignment="Right"
                                                                Style="{StaticResource ActionButton}"
                                                                Padding="14,6"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Border Background="#1A1A30" CornerRadius="8" Padding="20"
                                            Margin="0,8">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="🎮" FontSize="36" HorizontalAlignment="Center"/>
                                            <TextBlock Text="No games added yet" FontSize="14"
                                                       Foreground="#445" HorizontalAlignment="Center"
                                                       Margin="0,8,0,4"/>
                                            <TextBlock Text="Click '+ Add Game' to add your games"
                                                       FontSize="12" Foreground="#334"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ═══ OPTIMIZER PAGE ═══ -->
                        <StackPanel x:Name="PageOptimize" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="RAM CLEANER" FontSize="10" Foreground="#556"
                                                   FontWeight="Bold" Margin="0,0,0,12"/>
                                        <TextBlock x:Name="RamBeforeLabel" Text="Available: Loading..."
                                                   FontSize="13" Foreground="#888" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="RamFreedLabel" Text="" FontSize="13"
                                                   Foreground="#10B981"/>
                                        <Button Style="{StaticResource ActionButton}"
                                                Content="🧹  Clean RAM Now" Click="Optimize_Click"
                                                Margin="0,14,0,0" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="FPS ADVISOR" FontSize="10" Foreground="#556"
                                                   FontWeight="Bold" Margin="0,0,0,12"/>
                                        <ItemsControl x:Name="FpsTipsList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#1A1A30" CornerRadius="6"
                                                            Padding="10,8" Margin="0,3">
                                                        <TextBlock Text="{Binding}" Foreground="#AAA"
                                                                   FontSize="12" TextWrapping="Wrap"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Style="{StaticResource Card}" Margin="6,2,6,6">
                                <StackPanel>
                                    <TextBlock Text="GAME MODE" FontSize="10" Foreground="#556"
                                               FontWeight="Bold" Margin="0,0,0,12"/>
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="Boost FPS by disabling background apps and setting high CPU priority"
                                                       FontSize="12" Foreground="#667" Margin="0,0,0,12"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                    <Button Style="{StaticResource ActionButton}"
                                            x:Name="BtnGameMode2"
                                            Content="⚡  Enable Game Mode" Click="GameMode_Click"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ═══ MOUSE PAGE ═══ -->
                        <StackPanel x:Name="PageMouse" Visibility="Collapsed">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="MOUSE TWEAKS" FontSize="10" Foreground="#556"
                                               FontWeight="Bold" Margin="0,0,0,16"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Disable Mouse Acceleration" Foreground="#CCC"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Removes enhance pointer precision for consistent aim"
                                                       Foreground="#445" FontSize="11" Margin="0,2"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource Toggle}"
                                                  x:Name="ToggleMouseAccel" VerticalAlignment="Center"
                                                  Click="Mouse_Click"/>
                                    </Grid>
                                    <Border Height="1" Background="#1A1A3A" Margin="0,4,0,14"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Raw Input" Foreground="#CCC"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Use raw mouse input bypassing Windows processing"
                                                       Foreground="#445" FontSize="11" Margin="0,2"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource Toggle}"
                                                  x:Name="ToggleRawInput" VerticalAlignment="Center"
                                                  Click="Mouse_Click"/>
                                    </Grid>
                                    <Border Height="1" Background="#1A1A3A" Margin="0,4,0,14"/>
                                    <StackPanel>
                                        <TextBlock Text="Mouse DPI" Foreground="#CCC"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="DpiValueLabel" Text="800 DPI"
                                                   Foreground="#3B82F6" FontSize="20"
                                                   FontWeight="Bold" Margin="0,6,0,6"/>
                                        <Slider x:Name="DpiSlider" Minimum="400" Maximum="16000"
                                                Value="800" TickFrequency="400"
                                                IsSnapToTickEnabled="True"
                                                ValueChanged="Mouse_Click"
                                                Foreground="#3B82F6"/>
                                        <Grid Margin="0,4">
                                            <TextBlock Text="400" FontSize="10" Foreground="#445"/>
                                            <TextBlock Text="16000" FontSize="10" Foreground="#445"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ═══ KEYBOARD PAGE ═══ -->
                        <StackPanel x:Name="PageKeyboard" Visibility="Collapsed">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="KEYBOARD TWEAKS" FontSize="10" Foreground="#556"
                                               FontWeight="Bold" Margin="0,0,0,16"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Disable Sticky Keys" Foreground="#CCC"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Prevents Sticky Keys popup during gaming"
                                                       Foreground="#445" FontSize="11" Margin="0,2"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource Toggle}"
                                                  x:Name="ToggleStickyKeys" VerticalAlignment="Center"
                                                  Click="Keyboard_Click"/>
                                    </Grid>
                                    <Border Height="1" Background="#1A1A3A" Margin="0,4,0,14"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="High Repeat Rate" Foreground="#CCC"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Sets keyboard repeat rate to maximum"
                                                       Foreground="#445" FontSize="11" Margin="0,2"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource Toggle}"
                                                  x:Name="ToggleKeyRepeat" VerticalAlignment="Center"
                                                  Click="Keyboard_Click"/>
                                    </Grid>
                                    <Border Height="1" Background="#1A1A3A" Margin="0,4,0,14"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Disable Filter Keys" Foreground="#CCC"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Prevents Filter Keys from slowing key input"
                                                       Foreground="#445" FontSize="11" Margin="0,2"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource Toggle}"
                                                  x:Name="ToggleFilterKeys" VerticalAlignment="Center"
                                                  Click="Keyboard_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ═══ AUDIO PAGE ═══ -->
                        <StackPanel x:Name="PageAudio" Visibility="Collapsed">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="AUDIO SETTINGS" FontSize="10" Foreground="#556"
                                               FontWeight="Bold" Margin="0,0,0,16"/>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Disable Audio Enhancements" Foreground="#CCC"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Reduces audio latency for competitive gaming"
                                                       Foreground="#445" FontSize="11" Margin="0,2"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource Toggle}"
                                                  x:Name="ToggleAudioEnhance" VerticalAlignment="Center"
                                                  Click="Audio_Click"/>
                                    </Grid>
                                    <Border Height="1" Background="#1A1A3A" Margin="0,4,0,14"/>
                                    <StackPanel>
                                        <TextBlock Text="Master Volume" Foreground="#CCC"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="VolumeLabel" Text="100%"
                                                   Foreground="#8B5CF6" FontSize="20"
                                                   FontWeight="Bold" Margin="0,6,0,6"/>
                                        <Slider x:Name="VolumeSlider" Minimum="0" Maximum="100"
                                                Value="100" ValueChanged="Audio_Click"
                                                Foreground="#8B5CF6"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ═══ NETWORK PAGE ═══ -->
                        <StackPanel x:Name="PageNetwork" Visibility="Collapsed">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="NETWORK TOOLS" FontSize="10" Foreground="#556"
                                               FontWeight="Bold" Margin="0,0,0,12"/>
                                    <Button Style="{StaticResource ActionButton}"
                                            Content="📡  Run Ping Test" Click="Network_Click"
                                            HorizontalAlignment="Left" Margin="0,0,0,14"/>
                                    <Border x:Name="PingResultsBorder" Background="#0A0A1A"
                                            CornerRadius="8" Padding="14" Margin="0,0,0,14">
                                        <StackPanel>
                                            <TextBlock Text="PING RESULTS" FontSize="10" Foreground="#445"
                                                       FontWeight="Bold" Margin="0,0,0,10"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Google DNS" FontSize="11" Foreground="#556"/>
                                                    <TextBlock x:Name="Ping1" Text="-- ms"
                                                               FontSize="18" FontWeight="Bold"
                                                               Foreground="#3B82F6"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Cloudflare" FontSize="11" Foreground="#556"/>
                                                    <TextBlock x:Name="Ping2" Text="-- ms"
                                                               FontSize="18" FontWeight="Bold"
                                                               Foreground="#3B82F6"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="OpenDNS" FontSize="11" Foreground="#556"/>
                                                    <TextBlock x:Name="Ping3" Text="-- ms"
                                                               FontSize="18" FontWeight="Bold"
                                                               Foreground="#3B82F6"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    <Border Height="1" Background="#1A1A3A" Margin="0,4,0,14"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Disable Nagle's Algorithm" Foreground="#CCC"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text="Reduces latency for online gaming"
                                                       Foreground="#445" FontSize="11" Margin="0,2"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource Toggle}"
                                                  x:Name="ToggleNagle" VerticalAlignment="Center"
                                                  Click="Network_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ═══ CROSSHAIR PAGE ═══ -->
                        <StackPanel x:Name="PageCrosshair" Visibility="Collapsed">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="CROSSHAIR OVERLAY" FontSize="10" Foreground="#556"
                                               FontWeight="Bold" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="200"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                            <TextBlock Text="Color" Foreground="#888" FontSize="12" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <Border x:Name="CrosshairColorPreview" Width="32" Height="32"
                                                        CornerRadius="6" Background="#00FF00" Margin="0,0,8,0"
                                                        Cursor="Hand" MouseDown="Crosshair_Click"/>
                                                <TextBlock x:Name="CrosshairColorLabel" Text="#00FF00"
                                                           Foreground="#888" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="Size" Foreground="#888" FontSize="12" Margin="0,0,0,4"/>
                                            <Slider x:Name="CrosshairSize" Minimum="5" Maximum="40" Value="20"
                                                    ValueChanged="Crosshair_Click" Foreground="#3B82F6"/>
                                            <TextBlock Text="Thickness" Foreground="#888" FontSize="12"
                                                       Margin="0,10,0,4"/>
                                            <Slider x:Name="CrosshairThick" Minimum="1" Maximum="8" Value="2"
                                                    ValueChanged="Crosshair_Click" Foreground="#3B82F6"/>
                                            <TextBlock Text="Gap" Foreground="#888" FontSize="12"
                                                       Margin="0,10,0,4"/>
                                            <Slider x:Name="CrosshairGap" Minimum="0" Maximum="20" Value="4"
                                                    ValueChanged="Crosshair_Click" Foreground="#3B82F6"/>
                                            <Button Style="{StaticResource ActionButton}"
                                                    Content="🎯  Toggle Overlay" Click="Crosshair_Click"
                                                    Margin="0,14,0,0" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                        <!-- Crosshair Preview -->
                                        <Border Grid.Column="1" Background="#0A0A1A" CornerRadius="10">
                                            <Canvas x:Name="CrosshairCanvas" Width="180" Height="180">
                                                <!-- Crosshair drawn in code-behind -->
                                                <Line x:Name="ChTop" Canvas.Left="90" Canvas.Top="62"
                                                      X1="0" Y1="0" X2="0" Y2="24"
                                                      Stroke="#00FF00" StrokeThickness="2"/>
                                                <Line x:Name="ChBottom" Canvas.Left="90" Canvas.Top="94"
                                                      X1="0" Y1="0" X2="0" Y2="24"
                                                      Stroke="#00FF00" StrokeThickness="2"/>
                                                <Line x:Name="ChLeft" Canvas.Left="62" Canvas.Top="90"
                                                      X1="0" Y1="0" X2="24" Y2="0"
                                                      Stroke="#00FF00" StrokeThickness="2"/>
                                                <Line x:Name="ChRight" Canvas.Left="94" Canvas.Top="90"
                                                      X1="0" Y1="0" X2="24" Y2="0"
                                                      Stroke="#00FF00" StrokeThickness="2"/>
                                            </Canvas>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
