<Window x:Class="NovaGamingOptimizer.CrosshairWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nova Crosshair" Height="380" Width="540"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        MouseDown="Window_MouseDown">
    <Border Background="#0F0F0F" BorderBrush="#2A2A3A" BorderThickness="1" CornerRadius="10">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="CROSSHAIR DESIGNER" FontSize="17" FontWeight="Black" Foreground="#8844FF"/>
                    <TextBlock Text="Size - Thickness - Gap - Color" FontSize="11" Foreground="#444466" Margin="0,3,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="X" Click="Close_Click"
                        Background="Transparent" BorderThickness="0" Foreground="#FF4444" FontSize="14" Cursor="Hand"/>
            </Grid>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions><ColumnDefinition Width="190"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#030008" CornerRadius="10" Margin="0,0,16,0">
                    <Canvas x:Name="Preview" Width="190" Height="190" Background="Transparent"/>
                </Border>
                <StackPanel Grid.Column="1">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Size" FontSize="12" Foreground="#AAAACC" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="SizeSlider" Minimum="1" Maximum="40" Value="10" ValueChanged="Slider_Changed" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="SizeLabel" Text="10px" FontSize="11" Foreground="#8844FF" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Thickness" FontSize="12" Foreground="#AAAACC" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="ThickSlider" Minimum="1" Maximum="8" Value="2" ValueChanged="Slider_Changed" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="ThickLabel" Text="2px" FontSize="11" Foreground="#8844FF" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Gap" FontSize="12" Foreground="#AAAACC" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" x:Name="GapSlider" Minimum="0" Maximum="20" Value="4" ValueChanged="Slider_Changed" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="GapLabel" Text="4px" FontSize="11" Foreground="#8844FF" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="Color (Hex)" FontSize="12" Foreground="#AAAACC" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border x:Name="ColorPreview" Width="34" Height="34" CornerRadius="6" Background="#00FF88" Margin="0,0,8,0"/>
                        <TextBox x:Name="HexInput" Text="#00FF88"
                                 Background="#161616" Foreground="#00FF88"
                                 BorderBrush="#2A2A3A" BorderThickness="1"
                                 FontFamily="Courier New" FontSize="13" FontWeight="Bold"
                                 Width="120" VerticalContentAlignment="Center"
                                 TextChanged="HexInput_Changed"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Show" Click="ShowOverlay_Click"
                                Background="#8844FF" Foreground="#FFFFFF" BorderThickness="0"
                                FontWeight="Bold" Cursor="Hand" Margin="0,0,8,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="14,8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.85"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="Hide" Click="HideOverlay_Click"
                                Background="#1A0033" Foreground="#8844FF"
                                BorderBrush="#8844FF" BorderThickness="1"
                                FontWeight="Bold" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="14,8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.8"/></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
